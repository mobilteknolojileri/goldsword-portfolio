---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
import Services from "@/features/services";
import FAQ, { FAQ_DATA } from "@/features/faq";
import ThemeToggle from "@/components/layout/ThemeToggle";
import { generateMetadata } from "@/lib/seo/metadata";
import { getFAQSchema, getLocalBusinessSchema } from "@/lib/seo/schema";

const metadata = generateMetadata({
  title: "Gaziantep Web Site Yapımı ve Web Tasarım Hizmetleri",
  description:
    "Hızlı, güvenli ve SEO uyumlu web sitesi geliştirme. Gaziantep'teki işletmeler için ölçülebilir sonuç üreten dijital altyapı.",
  path: "/web-site-yapimi-gaziantep",
  locale: "tr",
  keywords: ["web site yapımı", "web tasarım gaziantep", "kurumsal web sitesi", "teknik seo"],
});

const extraSchemas = [getLocalBusinessSchema(), getFAQSchema(FAQ_DATA)];
---

<BaseLayout {...metadata} extraSchemas={extraSchemas}>
  <Navbar client:load />
  <ThemeToggle client:load />

  <main class="pt-24">
    <section class="bg-white py-20 dark:bg-dark-800">
      <div class="section-container section-padding mx-auto max-w-5xl text-center">
        <h1 class="mb-8 text-4xl font-black leading-tight text-heading sm:text-6xl">
          Web Siteniz Markanızın <span class="gradient-text">Dijital Satış Alanı</span>dır
        </h1>
        <p class="mx-auto mb-10 max-w-3xl text-xl leading-relaxed text-body">
          Sadece güzel görünen değil, hızlı açılan, güven veren ve dönüşüm üreten web siteleri
          geliştiriyoruz. Gaziantep'teki işletmeler için teknik kaliteyi iş hedefiyle
          birleştiriyoruz.
        </p>
        <a
          href="#contact"
          class="inline-block rounded-2xl bg-primary-600 px-10 py-5 text-lg font-black text-white shadow-xl shadow-primary-600/20 transition-all hover:scale-105 active:scale-95"
        >
          Projeyi Planlayalım
        </a>
      </div>
    </section>

    <Services client:visible />

    <section class="relative overflow-hidden bg-dark-900 py-20 text-white">
      <div class="absolute inset-0 translate-x-1/2 rounded-full bg-blue-600/10 blur-[120px]"></div>
      <div class="section-container section-padding relative z-10">
        <h2 class="mb-12 text-center text-3xl font-black text-white sm:text-4xl">
          Neden Bu Yaklaşım İşe Yarıyor?
        </h2>
        <div class="grid gap-8 sm:grid-cols-3">
          <div class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-md">
            <div class="mb-4 text-4xl">⚡</div>
            <h3 class="mb-3 text-xl font-bold">Hız Odaklı Altyapı</h3>
            <p class="text-white/70">
              Astro ve modern frontend mimarisi ile düşük bekleme süresi ve güçlü kullanıcı
              deneyimi.
            </p>
          </div>
          <div class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-md">
            <div class="mb-4 text-4xl">🎯</div>
            <h3 class="mb-3 text-xl font-bold">SEO Uyumlu Yapı</h3>
            <p class="text-white/70">
              Arama motorlarının doğru okuyabildiği, şema ve içerik kurgusu güçlü sayfa mimarisi.
            </p>
          </div>
          <div class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-md">
            <div class="mb-4 text-4xl">📱</div>
            <h3 class="mb-3 text-xl font-bold">Tam Mobil Deneyim</h3>
            <p class="text-white/70">
              Telefon, tablet ve masaüstü cihazlarda tutarlı hız, okunabilirlik ve etkileşim.
            </p>
          </div>
        </div>
      </div>
    </section>

    <FAQ client:visible />
  </main>
</BaseLayout>
