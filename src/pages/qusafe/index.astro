---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
import { qusafeMetadata } from "@/lib/seo/metadata";

const features = [
  {
    title: "Şifre Yönetimi",
    description: "Hassas parolalarınızı tek bir güvenli kasada saklayın.",
  },
  {
    title: "Güvenli Notlar",
    description: "Özel notlarınızı ve kişisel kayıtlarınızı güçlü şifreleme ile koruyun.",
  },
  {
    title: "Fotoğraf ve Video Kasası",
    description: "Medya dosyalarınızı cihazınızda şifreleyerek izinsiz erişime karşı koruyun.",
  },
];

const securityFeatures = [
  "AES-256-GCM ile cihaz üzerinde şifreleme",
  "Argon2id ile güçlü ana parola türetme",
  "Face ID / Parmak izi ile hızlı kilit açma",
  "Zero-Knowledge yaklaşımı (veriye sadece siz erişirsiniz)",
  "Parola güvenlik skoru ve zafiyet analizi",
];
---

<BaseLayout
  title={qusafeMetadata.title as string}
  description={qusafeMetadata.description as string}
  image="/qusafe-icon.png"
>
  <Navbar client:load />

  <div class="mx-auto max-w-5xl px-4 pb-20 pt-32">
    <section class="pb-20 text-center">
      <div class="relative mx-auto mb-10 h-32 w-32">
        <img
          src="/assets/projects/qusafe-mobile/icon.png"
          alt="QuSafe Logo"
          class="rounded-3xl shadow-2xl"
          width={128}
          height={128}
        />
      </div>

      <h1 class="text-heading mb-6 text-5xl font-bold tracking-tight md:text-7xl">
        QuSafe <span class="text-primary-600">Şifreli Kasa</span>
      </h1>
      <p class="text-body mx-auto mb-10 max-w-2xl text-xl md:text-2xl">
        Parola, not, fotoğraf ve videolarınızı modern güvenlik standartlarıyla koruyan kişisel
        güvenlik uygulaması.
      </p>

      <div class="flex justify-center gap-4">
        <a
          href="https://play.google.com/store/apps/details?id=com.schwerttr.qusafe"
          class="rounded-2xl bg-primary-600 px-8 py-4 font-bold text-white shadow-lg transition-all hover:bg-primary-700"
        >
          Google Play'den İndir
        </a>
      </div>
    </section>

    <section class="mb-32 grid gap-8 md:grid-cols-3">
      {
        features.map((feature) => (
          <div class="rounded-3xl border border-gray-100 bg-white p-8 shadow-sm dark:border-dark-700 dark:bg-dark-800">
            <h2 class="text-heading mb-3 text-xl font-bold">{feature.title}</h2>
            <p class="text-body">{feature.description}</p>
          </div>
        ))
      }
    </section>

    <section class="rounded-[2.5rem] bg-primary-50 p-12 text-center dark:bg-primary-900/10">
      <h2 class="text-heading mb-8 text-3xl font-bold md:text-5xl">Neden QuSafe?</h2>
      <div class="mx-auto grid max-w-2xl gap-4 md:grid-cols-1">
        {
          securityFeatures.map((feature) => (
            <div class="flex items-center gap-4 rounded-xl bg-white p-4 text-left shadow-sm dark:bg-dark-800">
              <span class="font-bold text-primary-600">✓</span>
              <span class="text-body font-medium">{feature}</span>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
