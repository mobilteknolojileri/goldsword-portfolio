---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
import Contact from "@/features/contact";
import Services from "@/features/services";
import FAQ, { FAQ_DATA } from "@/features/faq";
import ThemeToggle from "@/components/layout/ThemeToggle";
import { generateMetadata } from "@/lib/seo/metadata";
import { getFAQSchema, getLocalBusinessSchema } from "@/lib/seo/schema";

const metadata = generateMetadata({
  title: "Gaziantep Freelancer Yazılım Geliştirici ve Web Tasarım",
  description:
    "Gaziantep merkezli freelancer yazılım hizmetleri: web, mobil ve teknik SEO odaklı sürdürülebilir dijital çözümler.",
  path: "/gaziantep-freelancer",
  locale: "tr",
  keywords: [
    "gaziantep freelancer",
    "gaziantep yazılımcı",
    "web tasarım",
    "mobil uygulama geliştirme",
  ],
});

const extraSchemas = [getLocalBusinessSchema(), getFAQSchema(FAQ_DATA)];
---

<BaseLayout {...metadata} extraSchemas={extraSchemas}>
  <Navbar client:load />
  <ThemeToggle client:load />

  <main class="pt-24">
    <section class="bg-white py-20 dark:bg-dark-800">
      <div class="section-container section-padding">
        <div class="max-w-4xl">
          <h1 class="text-heading mb-8 text-4xl font-black leading-tight sm:text-6xl md:text-7xl">
            Gaziantep'te <span class="text-primary-600">Freelancer</span> Yazılım ve Dijital Üretim
          </h1>
          <p class="text-body mb-10 text-xl leading-relaxed">
            İşletmenizin ihtiyacına göre net bir teknik yol haritası kuruyoruz. Ajans karmaşasından
            uzak, doğrudan uzmanla çalışan ve ölçülebilir sonuç veren bir süreç sunuyoruz.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="#contact"
              class="rounded-2xl bg-primary-600 px-8 py-4 font-bold text-white shadow-lg transition-all hover:bg-primary-700"
              >Ücretsiz Ön Değerlendirme Al</a
            >
            <a
              href="/portfolio"
              class="text-heading rounded-2xl bg-gray-100 px-8 py-4 font-bold transition-all hover:bg-gray-200 dark:bg-dark-900 dark:hover:bg-dark-800"
              >Portfolyoyu İncele</a
            >
          </div>
        </div>
      </div>
    </section>

    <Services client:visible />

    <section
      class="border-y border-gray-100 bg-gray-50 py-20 dark:border-dark-800 dark:bg-dark-900"
    >
      <div class="section-container section-padding">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div>
            <h2 class="text-heading mb-6 text-3xl font-black">Neden Freelancer Modeli?</h2>
            <ul class="text-body space-y-4 text-lg">
              <li class="flex items-start gap-3">
                <span class="font-bold text-primary-600">></span> Doğrudan karar alıcı geliştirici ile
                iletişim.
              </li>
              <li class="flex items-start gap-3">
                <span class="font-bold text-primary-600">></span> Kapsama göre esnek, şeffaf ve kontrol
                edilebilir maliyet.
              </li>
              <li class="flex items-start gap-3">
                <span class="font-bold text-primary-600">></span> Hızlı revizyon ve teknik önceliklere
                göre net teslim planı.
              </li>
            </ul>
          </div>
          <div
            class="rounded-3xl border border-primary-100 bg-white p-8 shadow-xl dark:border-dark-700 dark:bg-dark-800"
          >
            <h3 class="text-heading mb-4 text-2xl font-bold">Yerel İş Ortamı Bilgisi</h3>
            <p class="text-body mb-6">
              Gaziantep ve Nizip bölgesindeki sektör dinamiklerini bilen bir yaklaşımla; sadece kod
              değil, iş hedefinize uyan dijital altyapı kuruyoruz.
            </p>
            <div
              class="rounded-xl border border-primary-100 bg-primary-50 p-4 text-center font-bold text-primary-700 dark:border-primary-800 dark:bg-primary-900/20 dark:text-primary-300"
            >
              Gaziantep / Nizip odaklı destek
            </div>
          </div>
        </div>
      </div>
    </section>

    <FAQ client:visible />
    <Contact client:load />
  </main>

  <footer class="border-t border-gray-100 bg-white py-10 dark:border-dark-800 dark:bg-dark-900">
    <div class="section-container section-padding">
      <p class="text-body text-center text-sm font-medium">
        © 2026 goldsword. Tüm hakları saklıdır.
      </p>
    </div>
  </footer>
</BaseLayout>
