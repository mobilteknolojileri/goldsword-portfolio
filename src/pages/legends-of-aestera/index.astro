---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
import { aesteraMetadata } from "@/lib/seo/metadata";

const features = [
  {
    title: "İki Farklı Karakter",
    description: "Red (Kılıç Kombo) ve Robinhood (Okçuluk) ile stratejinizi belirleyin.",
  },
  {
    title: "20+ El Yapımı Seviye",
    description: "Tuzaklar, gizli geçitler ve zorlu bulmacalarla dolu platformlar.",
  },
  {
    title: "Boss Savaşları",
    description: "Her bölüm sonunda reflekslerinizi zorlayacak epik dövüşler.",
  },
];

const techHighlights = [
  "Unity 2D Engine & C#",
  "Android Optimizasyonu (60 FPS)",
  "Touch & Gamepad Kontrol Desteği",
  "Dinamik Düşman AI Sistemi",
  "Piksel Art Grafik & Epik Müzikler",
];
---

<BaseLayout
  title={aesteraMetadata.title as string}
  description={aesteraMetadata.description as string}
  image="/assets/projects/legends-of-aestera/hero.webp"
>
  <Navbar client:idle />

  <div class="mx-auto max-w-5xl px-4 pb-20 pt-32">
    <section class="pb-20 text-center">
      <div
        class="relative mx-auto mb-10 w-full max-w-2xl overflow-hidden rounded-3xl border-4 border-primary-100 shadow-2xl"
      >
        <img
          src="/assets/projects/legends-of-aestera/hero.webp"
          alt="Legends of Aestera"
          class="h-auto w-full"
          width={800}
          height={450}
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <h1 class="text-heading mb-6 text-5xl font-bold tracking-tight md:text-7xl">
        Legends of <span class="text-primary-600">Aestera</span>
      </h1>
      <p class="text-body mx-auto mb-10 max-w-2xl text-xl md:text-2xl">
        Red ve Robinhood ile epik bir macera. Klasik platform ruhunu modern mekaniklerle birleştiren
        piksel oyun.
      </p>

      <div class="flex justify-center gap-4">
        <a
          href="https://play.google.com/store/apps/details?id=com.schwerttr.aestera"
          class="rounded-2xl bg-primary-600 px-8 py-4 font-bold text-white shadow-lg transition-all hover:bg-primary-700"
        >
          Google Play (Kapalı Test)
        </a>
      </div>
    </section>

    <section class="mb-32 grid gap-8 md:grid-cols-3">
      {
        features.map((feature) => (
          <div class="rounded-3xl border border-gray-100 bg-white p-8 shadow-sm dark:border-dark-700 dark:bg-dark-800">
            <h2 class="text-heading mb-3 text-xl font-bold">{feature.title}</h2>
            <p class="text-body">{feature.description}</p>
          </div>
        ))
      }
    </section>

    <section class="rounded-[2.5rem] bg-primary-50 p-12 text-center dark:bg-primary-900/10">
      <h2 class="text-heading mb-8 text-3xl font-bold md:text-5xl">Neden Aestera?</h2>
      <div class="mx-auto grid max-w-2xl gap-4 md:grid-cols-1">
        {
          techHighlights.map((feature) => (
            <div class="flex items-center gap-4 rounded-xl bg-white p-4 text-left shadow-sm dark:bg-dark-800">
              <span class="font-bold text-primary-600 dark:text-primary-400">✓</span>
              <span class="text-body font-medium">{feature}</span>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
