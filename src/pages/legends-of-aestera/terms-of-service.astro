---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";

const CONTACT_EMAIL = "mobilteknolojileri@gmail.com";
---

<BaseLayout
  title="Terms of Service - Legends of Aestera | goldsword"
  description="Terms of Service for Legends of Aestera mobile game."
>
  <Navbar client:load />

  <div class="mx-auto max-w-3xl px-4 pb-20 pt-32">
    <article>
      <div class="mb-8 border-b border-gray-200 pb-8 dark:border-dark-700">
        <h1 class="text-heading mb-4 text-3xl font-bold">Terms of Service</h1>
        <p class="text-body/60 italic">Son güncelleme / Last updated: 6 Şubat 2026</p>
      </div>

      <div
        class="rounded-3xl border border-gray-200 bg-gray-50 p-8 dark:border-dark-700 dark:bg-dark-800/50"
      >
        <div class="text-body space-y-8">
          <section>
            <h2 class="text-heading mb-3 text-xl font-semibold">1. Acceptance of Terms</h2>
            <p>
              By downloading or using Legends of Aestera, you agree to these terms. If you do not
              agree, please do not use the application.
            </p>
          </section>

          <section>
            <h2 class="text-heading mb-3 text-xl font-semibold">2. License</h2>
            <p>
              Broadly speaking: We grant you a personal, non-exclusive license to play the game on
              your own devices for non-commercial purposes.
            </p>
          </section>

          <section>
            <h2 class="text-heading mb-3 text-xl font-semibold">3. Prohibited Actions</h2>
            <p>
              You may not: reverse engineer, redistribute, or use the game contents for commercial
              gain without explicit permission.
            </p>
          </section>

          <section>
            <h2 class="text-heading mb-3 text-xl font-semibold">4. Disclaimer</h2>
            <p>
              The game is provided "as is". We are not responsible for any issues arising from
              hardware compatibility or data loss.
            </p>
          </section>

          <section>
            <h2 class="text-heading mb-3 text-xl font-semibold">5. Contact</h2>
            <p>
              Contact us at: <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="text-primary-600 underline transition-colors hover:text-primary-700"
                >{CONTACT_EMAIL}</a
              >
            </p>
          </section>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
