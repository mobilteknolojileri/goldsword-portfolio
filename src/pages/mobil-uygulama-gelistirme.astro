---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
import Services from "@/features/services";
import FAQ, { FAQ_DATA } from "@/features/faq";
import ThemeToggle from "@/components/layout/ThemeToggle";
import { generateMetadata } from "@/lib/seo/metadata";
import { getFAQSchema, getLocalBusinessSchema } from "@/lib/seo/schema";

const metadata = generateMetadata({
  title: "Mobil Uygulama Geliştirme | Flutter ve React Native",
  description:
    "iOS ve Android için hızlı, güvenli ve ölçeklenebilir mobil uygulama geliştirme. Tek kod tabanı ile sürdürülebilir ürün süreci.",
  path: "/mobil-uygulama-gelistirme",
  locale: "tr",
  keywords: ["mobil uygulama geliştirme", "flutter", "react native", "ios", "android"],
});

const extraSchemas = [getLocalBusinessSchema(), getFAQSchema(FAQ_DATA)];
---

<BaseLayout {...metadata} extraSchemas={extraSchemas}>
  <Navbar client:load />
  <ThemeToggle client:load />

  <main class="pt-24">
    <section class="bg-white py-20 dark:bg-dark-800">
      <div class="section-container section-padding">
        <div class="max-w-4xl">
          <h1 class="text-heading mb-8 text-4xl font-black sm:text-6xl">
            Fikrinizi <span class="text-primary-600">Çalışan Bir Mobil Ürüne</span> Dönüştürelim
          </h1>
          <p class="text-body mb-10 text-xl leading-relaxed">
            Sadece uygulama geliştirmiyoruz; hedef kitlenize ulaşan, performanslı ve bakımı kolay
            bir ürün altyapısı kuruyoruz. Flutter ve React Native ile iOS ve Android sürecini
            hızlandırıyoruz.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="#contact"
              class="rounded-2xl bg-primary-600 px-8 py-4 font-bold text-white shadow-lg transition-colors hover:bg-primary-700"
              >Teklif Al</a
            >
            <a
              href="/portfolio/"
              class="rounded-2xl border-2 border-gray-100 px-8 py-4 font-bold transition-colors hover:bg-gray-50 dark:border-dark-700 dark:hover:bg-dark-900"
              >Örnek Projeler</a
            >
          </div>
        </div>
      </div>
    </section>

    <Services client:visible />

    <section
      class="overflow-hidden border-y border-gray-100 bg-gray-50 py-24 dark:border-dark-800 dark:bg-dark-900"
    >
      <div class="section-container section-padding">
        <h2 class="text-heading mb-16 text-center text-3xl font-black">Üretim Süreci</h2>
        <div class="grid gap-8 md:grid-cols-4">
          {
            [
              {
                step: "01",
                title: "Analiz",
                desc: "İş hedefi, kullanıcı akışı ve teknik kapsam netleşir.",
              },
              {
                step: "02",
                title: "Tasarım",
                desc: "Ekran akışları, etkileşimler ve bilgi mimarisi oluşturulur.",
              },
              {
                step: "03",
                title: "Geliştirme",
                desc: "Temiz kod, performans ve test odaklı uygulama yazılır.",
              },
              {
                step: "04",
                title: "Yayın ve Bakım",
                desc: "Store süreci, izleme ve sürekli iyileştirme planlanır.",
              },
            ].map((s) => (
              <div class="relative rounded-3xl border border-gray-100 bg-white p-8 dark:border-dark-700 dark:bg-dark-800">
                <span class="absolute right-6 top-4 text-6xl font-black text-primary-600/10">
                  {s.step}
                </span>
                <h3 class="text-heading mb-3 text-xl font-bold">{s.title}</h3>
                <p class="text-body">{s.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <FAQ client:visible />
  </main>
</BaseLayout>
