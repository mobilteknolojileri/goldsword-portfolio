---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar";
---

<BaseLayout
  title="404 — Sayfa Bulunamadı | goldsword"
  description="Aradığınız sayfa bulunamadı. Ana sayfaya dönebilir veya diğer sayfaları keşfedebilirsiniz."
>
  <Navbar client:load />

  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="text-center">
      <div class="mb-8">
        <span
          class="gradient-text text-[8rem] font-black leading-none tracking-tighter sm:text-[12rem]"
        >
          404
        </span>
      </div>

      <h1 class="text-heading mb-4 text-2xl font-bold sm:text-3xl">Sayfa Bulunamadı</h1>

      <p class="text-body mx-auto mb-10 max-w-md text-lg leading-relaxed">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-2xl bg-primary-600 px-8 py-4 font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:bg-primary-700 hover:shadow-xl"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            ></path>
          </svg>
          Ana Sayfaya Dön
        </a>

        <a
          href="/blog"
          class="text-heading inline-flex items-center gap-2 rounded-2xl border-2 border-gray-200 px-8 py-4 font-bold transition-all hover:-translate-y-1 hover:border-primary-500 hover:shadow-lg dark:border-dark-700 dark:hover:border-primary-500"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
            ></path>
          </svg>
          Blog'u Keşfet
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
