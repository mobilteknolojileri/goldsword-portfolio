{
  "name": "portfolio-astro",
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && eslint \"src/**/*.{ts,tsx}\" && prettier --check \"**/*.{astro,tsx,ts,md,json,css,mjs}\"",
    "fix": "eslint \"src/**/*.{ts,tsx}\" --fix && prettier --write \"**/*.{astro,tsx,ts,md,json,css,mjs}\" && astro check",
    "lighthouse": "unlighthouse --site http://localhost:4321",
    "lighthouse:ci": "unlighthouse-ci --site http://localhost:4321",
    "lighthouse:live": "unlighthouse --site https://goldsword.dev"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@emailjs/browser": "^4.4.1",
    "@hookform/resolvers": "^5.2.2",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^10.0.2",
    "react-type-animation": "^3.2.0",
    "tailwind-merge": "^3.4.1",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/rss": "^4.0.15",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^8.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@unlighthouse/cli": "^0.17.7",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^3.4.19"
